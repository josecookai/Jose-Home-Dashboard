# ============================================================
# Jose Home Dashboard — Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit the real .env file to version control.
# ============================================================


# ------------------------------------------------------------
# Supabase
# ------------------------------------------------------------

# Public URL for your Supabase project (used by Next.js frontend + Python scripts)
# Format: https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Anon/public key — safe to expose to the browser (read-only RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — KEEP SECRET, only used by server-side scripts
# Grants full database access, bypasses RLS
SUPABASE_SERVICE_KEY=


# ------------------------------------------------------------
# Telegram notifications
# ------------------------------------------------------------

# Bot token from @BotFather (format: 123456789:ABCDefGHijKlmNoPQRstUVwXyz)
TELEGRAM_BOT_TOKEN=

# Chat ID to send notifications to (use @userinfobot to find yours)
# Can be a personal chat ID (positive integer) or a group ID (negative integer)
TELEGRAM_CHAT_ID=


# ------------------------------------------------------------
# Strava
# ------------------------------------------------------------

# OAuth app credentials from https://www.strava.com/settings/api
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# Tokens obtained via the OAuth flow (scripts/strava_auth.py can generate these)
STRAVA_ACCESS_TOKEN=
STRAVA_REFRESH_TOKEN=


# ------------------------------------------------------------
# GitHub
# ------------------------------------------------------------

# Personal access token (classic) or fine-grained token
# Required scopes: public_repo (or repo for private repos)
GITHUB_TOKEN=


# ------------------------------------------------------------
# LEAPS options position
# ------------------------------------------------------------

# Underlying ticker to monitor (default: AMZN)
LEAPS_TICKER=AMZN

# Strike price of your LEAPS call option (e.g. 200)
LEAPS_STRIKE=

# Expiry date of your LEAPS call option (YYYY-MM-DD format, e.g. 2026-01-16)
LEAPS_EXPIRY=2026-01-16
